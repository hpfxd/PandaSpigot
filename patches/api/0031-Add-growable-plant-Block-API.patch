From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WilyWork <hezodions@gmail.com>
Date: Tue, 30 Jun 2026 22:02:59 -0300
Subject: [PATCH] Add growable plant Block API

Expose age-based plant growth helpers through the public Block interface so plugins do not need to depend on internal NMS classes.

diff --git a/src/main/java/org/bukkit/block/Block.java b/src/main/java/org/bukkit/block/Block.java
index 235c15bdfed7a593d408a5b4103aa857824b29f8..5fe0072d069554cf2de48c21e2419dbc64d3d001 100644
--- a/src/main/java/org/bukkit/block/Block.java
+++ b/src/main/java/org/bukkit/block/Block.java
@@ -316,6 +316,37 @@ public interface Block extends Metadatable {
      */
     int getBlockPower();
 
+    // PandaSpigot start - Add growable plant API
+    /**
+     * Checks if this block is an age-based growable plant.
+     *
+     * @return true if this block has age-based plant growth
+     */
+    boolean isGrowablePlant();
+
+    /**
+     * Gets the current age-based growth level of this block.
+     *
+     * @return the current growth level, or -1 if this block is not growable
+     */
+    int getGrowthLevel();
+
+    /**
+     * Gets the maximum age-based growth level this block can reach.
+     *
+     * @return the maximum growth level, or -1 if this block is not growable
+     */
+    int getMaxGrowthLevel();
+
+    /**
+     * Checks if this block is an age-based growable plant that has reached
+     * its maximum growth level.
+     *
+     * @return true if this block is fully grown
+     */
+    boolean isFullyGrown();
+    // PandaSpigot end
+
     /**
      * Checks if this block is empty.
      * <p>
