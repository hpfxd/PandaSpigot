diff --git a/src/main/java/net/minecraft/server/PandaGrowablePlant.java b/src/main/java/net/minecraft/server/PandaGrowablePlant.java
new file mode 100644
index 0000000000000000000000000000000000000000..e16a9d0cd5e4c386e3b03be4c82788bb69389ce5
--- /dev/null
+++ b/src/main/java/net/minecraft/server/PandaGrowablePlant.java
@@ -0,0 +1,31 @@
+package net.minecraft.server;
+
+public interface PandaGrowablePlant {
+
+    BlockStateInteger getGrowthState();
+
+    static PandaGrowablePlant getById(int id) {
+        Block block = Block.getById(id);
+        return block instanceof PandaGrowablePlant ? (PandaGrowablePlant) block : null;
+    }
+
+    static boolean isGrowablePlant(int id) {
+        return getById(id) != null;
+    }
+
+    default int getGrowthLevel(IBlockData iblockdata) {
+        return ((Integer) iblockdata.get(this.getGrowthState())).intValue();
+    }
+
+    default int getGrowthLevel(int legacyData) {
+        return this.getGrowthLevel(((Block) this).fromLegacyData(legacyData));
+    }
+
+    default int getMaxGrowthLevel() {
+        return this.getGrowthState().getMaxValue();
+    }
+
+    default boolean isFullyGrown(IBlockData iblockdata) {
+        return this.getGrowthLevel(iblockdata) >= this.getMaxGrowthLevel();
+    }
+}
